#include <physical_layouts.dtsi>

/ {
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan>;

        keys
        //                          w    h     x     y  rot  rx  ry
        // Row 0 (12 keys): Esc Q W E R T Y U I O P Backspace
            = <&key_physical_attrs 100 100     0     0  0 0 0>  // Esc
            , <&key_physical_attrs 100 100   100     0  0 0 0>  // Q
            , <&key_physical_attrs 100 100   200     0  0 0 0>  // W
            , <&key_physical_attrs 100 100   300     0  0 0 0>  // E
            , <&key_physical_attrs 100 100   400     0  0 0 0>  // R
            , <&key_physical_attrs 100 100   500     0  0 0 0>  // T
            , <&key_physical_attrs 100 100   600     0  0 0 0>  // Y
            , <&key_physical_attrs 100 100   700     0  0 0 0>  // U
            , <&key_physical_attrs 100 100   800     0  0 0 0>  // I
            , <&key_physical_attrs 100 100   900     0  0 0 0>  // O
            , <&key_physical_attrs 100 100  1000     0  0 0 0>  // P
            , <&key_physical_attrs 150 100  1100     0  0 0 0>  // Backspace (1.5u)
        // Row 1 (11 keys): A S D F G H J K L Ñ Enter — stagger +25
            , <&key_physical_attrs 100 100    25   100  0 0 0>  // A
            , <&key_physical_attrs 100 100   125   100  0 0 0>  // S
            , <&key_physical_attrs 100 100   225   100  0 0 0>  // D
            , <&key_physical_attrs 100 100   325   100  0 0 0>  // F
            , <&key_physical_attrs 100 100   425   100  0 0 0>  // G
            , <&key_physical_attrs 100 100   525   100  0 0 0>  // H
            , <&key_physical_attrs 100 100   625   100  0 0 0>  // J
            , <&key_physical_attrs 100 100   725   100  0 0 0>  // K
            , <&key_physical_attrs 100 100   825   100  0 0 0>  // L
            , <&key_physical_attrs 100 100   925   100  0 0 0>  // Ñ
            , <&key_physical_attrs 150 100  1025   100  0 0 0>  // Enter (1.5u)
        // Row 2 (9 keys): Z X C V B N M Layer+ Layer- — stagger +50
            , <&key_physical_attrs 100 100    50   200  0 0 0>  // Z
            , <&key_physical_attrs 100 100   150   200  0 0 0>  // X
            , <&key_physical_attrs 100 100   250   200  0 0 0>  // C
            , <&key_physical_attrs 100 100   350   200  0 0 0>  // V
            , <&key_physical_attrs 100 100   450   200  0 0 0>  // B
            , <&key_physical_attrs 100 100   550   200  0 0 0>  // N
            , <&key_physical_attrs 100 100   650   200  0 0 0>  // M
            , <&key_physical_attrs 100 100   950   200  0 0 0>  // Layer+
            , <&key_physical_attrs 100 100  1050   200  0 0 0>  // Layer-
        // Row 3 (4 keys): Shift Ctrl Super Space
            , <&key_physical_attrs 100 100     0   300  0 0 0>  // Shift
            , <&key_physical_attrs 100 100   100   300  0 0 0>  // Ctrl
            , <&key_physical_attrs 100 100   200   300  0 0 0>  // Super
            , <&key_physical_attrs 500 100   350   300  0 0 0>  // Space (5u wide)
            ;
    };
};
